{
  "appId": "com.telegramgroupmessenger.app.premium",
  "productName": "Telegram Group Messenger Premium",
  "directories": {
    "output": "dist-premium"
  },
  "win": {
    "target": "nsis",
    "icon": "assets/icon.ico"
  },
  "nsis": {
    "oneClick": false,
    "perMachine": false,
    "allowElevation": false,
    "allowToChangeInstallationDirectory": true,
    "installerIcon": "assets/icon.ico",
    "uninstallerIcon": "assets/icon.ico"
  },
  "files": [
    "**/*",
    "!node_modules/**/*",
    "!dist/**/*",
    "!dist-demo/**/*",
    "!dist-premium/**/*",
    "!_vendor/**/*",
    "!data/**/*"
  ],
  "asarUnpack": [
    "requirements.txt",
    "backend/*.py"
  ],
  "extraMetadata": {
    "edition": "premium",
    "demoMode": false,
    "demoMinutes": 15,
    "accountLimit": 100
  }
}
