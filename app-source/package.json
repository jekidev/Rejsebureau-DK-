{
  "name": "telegram-group-messenger",
  "version": "1.0.3",
  "description": "Professional Telegram Group Message Sender with Rate Limiting",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:win": "electron-builder --win --x64 --config electron-builder.premium.json",
    "dev": "electron . --dev"
  },
  "keywords": [
    "telegram",
    "messaging",
    "automation",
    "electron"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "dependencies": {
    "electron-log": "^5.1.4",
    "electron-updater": "^6.3.0",
    "qrcode": "^1.5.3"
  },
  "build": {
    "appId": "com.telegramgroupmessenger.app",
    "productName": "Telegram Group Messenger",
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "differentialPackage": false
    },
    "files": [
      "**/*",
      "!dist/**/*",
      "!_vendor/**/*",
      "!data/**/*"
    ],
    "asarUnpack": [
      "requirements.txt",
      "backend/*.py"
    ],
    "extraMetadata": {
      "edition": "standard",
      "demoMode": false,
      "demoMinutes": 15,
      "accountLimit": 10
    },
    "publish": [
      {
        "provider": "github",
        "releaseType": "release"
      }
    ]
  }
}
